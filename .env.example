# ══════════════════════════════════════════════════════════
#  GNC College Website — Firebase Environment Variables
#  
#  STEPS:
#  1. Is file ko copy karke naam ".env" rakh do (root folder mein)
#  2. Apni Firebase Console se values fill karo
#  3. Firebase Console → Project Settings → Your Apps → Config
#  4. .env file kabhi bhi GitHub pe push mat karo!
# ══════════════════════════════════════════════════════════

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Admin Login Credentials ──────────────────────────────────────────
# (optional — default: admin / admin123 — zaroor change karo!)
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=your_strong_password_here
